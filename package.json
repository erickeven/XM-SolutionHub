{
  "name": "xinmaowei-design-in-platform",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^11.0.0"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r dev",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "e2e": "pnpm --filter @xinmaowei/client e2e",
    "prisma:generate": "pnpm --filter @xinmaowei/server prisma:generate",
    "verify": "pnpm prisma:generate && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
