{
  "name": "@xinmaowei/server",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "worker": "tsx src/worker.ts",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "admin:init": "tsx scripts/admin-init.ts"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "7.8.0",
    "@prisma/client": "7.8.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "mariadb": "3.5.3",
    "minio": "8.0.7",
    "pdf-lib": "1.17.1",
    "redis": "6.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/supertest": "7.2.0",
    "prisma": "7.8.0",
    "supertest": "7.2.2",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
